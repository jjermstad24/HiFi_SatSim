/*************     TRICK HEADER     ******************************************
VehicleBasicSimObject
Purpose:( This sim object models a very basic vehicle.)
*****************************************************************************/
#ifndef SIM_OBJECT_VEHICLE_BASIC
#define SIM_OBJECT_VEHICLE_BASIC

##include <nlohmann/json.hpp>

##include "dynamics/dyn_body/include/dyn_body.hh"
##include "environment/gravity/include/spherical_harmonics_gravity_controls.hh"
##include "dynamics/body_action/include/dyn_body_init_trans_state.hh"
##include "dynamics/body_action/include/dyn_body_init_rot_state.hh"
##include "dynamics/body_action/include/mass_body_init.hh"

##include "dynamics/derived_state/include/orb_elem_derived_state.hh"
##include "dynamics/derived_state/include/planetary_derived_state.hh"
##include "dynamics/derived_state/include/euler_derived_state.hh"
##include "dynamics/derived_state/include/lvlh_derived_state.hh"

##include "actuators/magnetorquer/include/magnetorquer.hh"
##include "actuators/rcs/include/rcs_cluster.hh"
##include "actuators/reaction_wheel/include/rw_cluster.hh"

##include "environment/gravity/include/gravity_manager.hh"
##include "environment/earth_magnetic_field/include/earth_magnetic_field.hh"

##include "guidance/include/guidance.hh"
##include "control/include/gnc_mode.hh"
##include "control/include/control.hh"
##include "control/include/allocator.hh"
##include "fsw_management/include/sim2fsw_bus.hh"
##include "fsw_management/include/fsw2sim_bus.hh"
##include "fsw_management/include/fsw.hh"
##include "fsw_management/include/ground_target_data.hh"

class VehicleSimObject : public Trick::SimObject
{
protected:
    jeod::DynManager & dyn_manager;

public:
    //----------------------------------------
    // Core vehicle
    //----------------------------------------
    jeod::DynBody dyn_body;

    //----------------------------------------
    // Targets – pointers to ground target state objects registered via
    // add_target() from the Python input file.
    //----------------------------------------
    static const int MAX_TRACKED_TARGETS = 10;
    int num_tracked_targets = 0;
    GroundTargetData* tracked_targets[MAX_TRACKED_TARGETS];

    /** Call from the Python input file for each target object. */
    void add_target(GroundTargetData* tgt) {
        if (num_tracked_targets < MAX_TRACKED_TARGETS) {
            tracked_targets[num_tracked_targets++] = tgt;
        }
    }

    //----------------------------------------
    // Gravity
    //----------------------------------------
    jeod::SphericalHarmonicsGravityControls earth_grav_control;
    jeod::SphericalHarmonicsGravityControls moon_grav_control;
    jeod::SphericalHarmonicsGravityControls sun_grav_control;

    //----------------------------------------
    // Environment
    //----------------------------------------
    gnc::EarthMagneticField mag_field;

    //----------------------------------------
    // Initialization
    //----------------------------------------
    jeod::DynBodyInitTransState trans_init;
    jeod::DynBodyInitRotState rot_init;
    jeod::MassBodyInit mass_init;

    //----------------------------------------
    // Derived states
    //----------------------------------------
    jeod::OrbElemDerivedState orb_elem;
    jeod::PlanetaryDerivedState pfix;
    jeod::EulerDerivedState euler_rpy;
    jeod::LvlhDerivedState lvlh;

    //----------------------------------------
    // ACTUATORS
    //----------------------------------------

    gnc::Magnetorquer magnetorquer;
    gnc::RCSCluster rcs_cluster;
    gnc::RWCluster rw_cluster;

    //----------------------------------------
    // GNC
    //----------------------------------------
    gnc::Fsw fsw;
    gnc::Sim2FswBus sim2fsw_bus;
    gnc::Fsw2SimBus fsw2sim_bus;

    //----------------------------------------
    // Default Data
    //----------------------------------------
    void load_config(const std::string& filepath) {
        std::ifstream file(filepath);
        if (!file.is_open()) {
            throw std::runtime_error("Failed to open config file: " + filepath);
        }

        nlohmann::json j;
        file >> j;

        //----------------------------------------
        // MAGNETORQUER
        //----------------------------------------
        if (j.contains("magnetorquer")) {
            auto& mtq = j["magnetorquer"];

            magnetorquer.R = mtq.value("R", magnetorquer.R);
            magnetorquer.L = mtq.value("L", magnetorquer.L);
            magnetorquer.max_current = mtq.value("max_current", magnetorquer.max_current);
            magnetorquer.max_dipole = mtq.value("max_dipole", magnetorquer.max_dipole);
            magnetorquer.N = mtq.value("N", magnetorquer.N);
            magnetorquer.area = mtq.value("area", magnetorquer.area);

            magnetorquer.initialize();
        }

        //----------------------------------------
        // RCS CLUSTER
        //----------------------------------------
        if (j.contains("rcs_cluster")) {
            auto& rcs = j["rcs_cluster"];

            if (rcs.contains("thrusters")) {
                auto& thrusters = rcs["thrusters"];

                for (size_t i = 0; i < thrusters.size(); i++) {
                    auto& t = thrusters[i];

                    // Position
                    if (t.contains("position")) {
                        for (int k = 0; k < 3; k++) {
                            rcs_cluster.thrusters[i].position[k] = t["position"][k];
                        }
                    }

                    // Direction
                    if (t.contains("direction")) {
                        for (int k = 0; k < 3; k++) {
                            rcs_cluster.thrusters[i].direction[k] = t["direction"][k];
                        }
                    }

                    // Optional parameters
                    rcs_cluster.thrusters[i].thrust_vac = t.value("thrust_vac", 6.0);
                    rcs_cluster.thrusters[i].Isp = t.value("Isp", 220.0);
                    rcs_cluster.thrusters[i].chamber_pressure_nom = t.value("chamber_pressure_nom", 2e5);
                    rcs_cluster.thrusters[i].valve_tau = t.value("valve_tau", 0.02);
                    rcs_cluster.thrusters[i].pressure_tau = t.value("pressure_tau", 0.05);
                    rcs_cluster.thrusters[i].min_on_time = t.value("min_on_time", 0.01);

                    rcs_cluster.thrusters[i].initialize();
                }
            }
        }

        //----------------------------------------
        // REACTION WHEELS
        //----------------------------------------
        if (j.contains("reaction_wheels")) {
            auto& rw = j["reaction_wheels"];

            rw_cluster.num_wheels = rw.value("num_wheels", 3);

            if (rw.contains("wheels")) {
                for (size_t i = 0; i < rw["wheels"].size(); i++) {
                    auto& w = rw["wheels"][i];

                    if (w.contains("axis")) {
                        for (int k = 0; k < 3; k++) {
                            rw_cluster.wheels[i].axis[k] = w["axis"][k];
                        }
                    }

                    rw_cluster.wheels[i].J = w.value("J", 0.001);
                    rw_cluster.wheels[i].max_torque = w.value("max_torque", 0.02);
                    rw_cluster.wheels[i].max_speed = w.value("max_speed", 6000.0 * 2.0 * 3.14159 / 60.0);

                    rw_cluster.wheels[i].viscous_friction = w.value("viscous_friction", 1e-5);
                    rw_cluster.wheels[i].coulomb_friction = w.value("coulomb_friction", 1e-4);
                    rw_cluster.wheels[i].torque_rate_limit = w.value("torque_rate_limit", 0.1);

                    rw_cluster.wheels[i].initialize();
                }
            }
        }

        std::cout << "[VehicleSimObject] Loaded config: " << filepath << std::endl;
    }

    //----------------------------------------
    // Constructor
    //----------------------------------------
    VehicleSimObject(jeod::DynManager & dyn_mngr_in)
        : dyn_manager(dyn_mngr_in), num_tracked_targets(0)
    {
        //----------------------------------------
        // Dyn body init
        //----------------------------------------
        P_ENV("initialization")
        dyn_body.initialize_model(dyn_manager);

        //----------------------------------------
        // Derived states init
        //----------------------------------------
        P_DYN("initialization") orb_elem.initialize(dyn_body, dyn_manager);
        P_DYN("initialization") pfix.initialize(dyn_body, dyn_manager);
        P_DYN("initialization") euler_rpy.initialize(dyn_body, dyn_manager);
        P_DYN("initialization") lvlh.initialize(dyn_body, dyn_manager);

        fsw.initialize();
        fsw_substep = 0;

        //----------------------------------------
        // ACTUATOR UPDATE (physics, 200 Hz; holds FSW commands between updates)
        //----------------------------------------
        magnetorquer.update(DYNAMICS);
        rw_cluster.update(DYNAMICS);
        rcs_cluster.update(DYNAMICS);
        P_DYN(DYNAMICS, "environment") update();
    }

    //----------------------------------------
    // Runtime update (Trick job): 200 Hz; FSW block at 40 Hz (FSW_STRIDE).
    //----------------------------------------
private:
    /** Sub-step within [0 .. FSW_STRIDE-1]; FSW runs when zero (40 Hz vs 200 Hz dynamics). */
    unsigned fsw_substep;

    void update()
{
    //----------------------------------------
    // Derived states
    //----------------------------------------
    orb_elem.update();
    pfix.update();
    lvlh.update();
    euler_rpy.update();

    //----------------------------------------
    // ================================
    // STATE EXTRACTION (JEOD → GNC)
    // ================================
    //----------------------------------------

    double r_eci[3];
    double v_eci[3];
    double w_body[3];
    double q_body_eci[4];

    // Position / velocity (inertial)
    for (int i = 0; i < 3; i++) {
        r_eci[i] = dyn_body.composite_body.state.trans.position[i];
        v_eci[i] = dyn_body.composite_body.state.trans.velocity[i];
        w_body[i] = dyn_body.composite_body.state.rot.ang_vel_this[i];
    }

    // Local Magnetic Field
    double B_eci[3];
    mag_field.compute(r_eci, exec_get_sim_time(), B_eci);
    double B_body[3];
    jeod::Quaternion q_eci_to_body;
    dyn_body.composite_body.state.rot.Q_parent_this.conjugate(q_eci_to_body);
    q_eci_to_body.left_quat_transform(B_eci, B_body);

    //----------------------------------------
    // ================================
    // POPULATE SIM2FSW_BUS
    // ================================
    //----------------------------------------
    for (int i = 0; i < 3; i++) {
        sim2fsw_bus.r_eci[i] = r_eci[i];
        sim2fsw_bus.v_eci[i] = v_eci[i];
        sim2fsw_bus.w_body[i] = w_body[i];
        sim2fsw_bus.B_body[i] = B_body[i];
    }
    
    sim2fsw_bus.num_targets = 0;
    for (int i = 0; i < num_tracked_targets; i++) {
        if (tracked_targets[i] && i < gnc::Sim2FswBus::max_targets) {
            sim2fsw_bus.target_eci[i][0] = tracked_targets[i]->pos_inertial[0];
            sim2fsw_bus.target_eci[i][1] = tracked_targets[i]->pos_inertial[1];
            sim2fsw_bus.target_eci[i][2] = tracked_targets[i]->pos_inertial[2];
            sim2fsw_bus.num_targets++;
        }
    }

    dyn_body.composite_body.state.rot.Q_parent_this.conjugate(sim2fsw_bus.q_eci_to_body);
    sim2fsw_bus.sim_time = exec_get_sim_time();
    sim2fsw_bus.fsw_dt = FSW_DT;

    //----------------------------------------
    // ================================
    // FSW UPDATE
    // ================================
    //----------------------------------------
    fsw.update(sim2fsw_bus, fsw2sim_bus);

    //----------------------------------------
    // ================================
    // APPLY FSW2SIM_BUS COMMANDS TO ACTUATORS
    // ================================
    //----------------------------------------
    for (int i = 0; i < 3; i++) {
        rw_cluster.torque_cmd[i] = fsw2sim_bus.rw_torque_cmd[i];
        magnetorquer.cmd_dipole_body[i] = fsw2sim_bus.mtq_dipole_cmd[i];
    }

    for (int i = 0; i < gnc::Fsw2SimBus::num_rcs_thrusters; i++) {
        rcs_cluster.thrusters[i].cmd = fsw2sim_bus.rcs_thruster_cmd[i];
    }

    // Step actuator internal dynamics every vehicle update so commanded
    // actuator states produce force/torque in this run.
    magnetorquer.update(DYNAMICS);
    rw_cluster.update(DYNAMICS);
    rcs_cluster.update(DYNAMICS);
}

    VehicleSimObject(const VehicleSimObject &);
    VehicleSimObject & operator=(const VehicleSimObject &);
};

#endif